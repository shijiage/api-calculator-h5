{
	"bsonType": "object",
	"required": ["openid", "report_id", "title", "ts", "payload"],
	"permission": {
		"read": false,
		"create": false,
		"update": false,
		"delete": false
	},
	"properties": {
		"openid": {
			"bsonType": "string",
			"description": "用户微信 openid"
		},
		"report_id": {
			"bsonType": "string",
			"description": "客户端生成的报告 id，与页面 query.id 一致"
		},
		"title": {
			"bsonType": "string",
			"description": "列表展示标题"
		},
		"ts": {
			"bsonType": "long",
			"description": "生成时间（毫秒时间戳）"
		},
		"saving_cny": {
			"bsonType": "double",
			"description": "本次估算节省人民币，可空"
		},
		"payload": {
			"bsonType": "object",
			"description": "完整报告 JSON，与 REPORT_STORAGE_KEY 结构一致"
		},
		"site_a": {
			"bsonType": "object",
			"description": "生成报告时站点 A 配置（与 initialSiteA 结构一致），旧数据可缺省"
		},
		"site_b": {
			"bsonType": "object",
			"description": "生成报告时站点 B 配置"
		}
	}
}
