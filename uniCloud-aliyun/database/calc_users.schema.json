{
	"bsonType": "object",
	"required": ["openid"],
	"permission": {
		"read": false,
		"create": false,
		"update": false,
		"delete": false
	},
	"properties": {
		"openid": {
			"bsonType": "string",
			"description": "用户唯一标识，小程序端为微信 openid，H5 端为 web_ 前缀用户 ID"
		},
		"unionid": {
			"bsonType": "string",
			"description": "微信 unionid，可为空"
		},
		"username": {
			"bsonType": "string",
			"description": "H5 账号名"
		},
		"username_key": {
			"bsonType": "string",
			"description": "H5 账号名的小写检索键"
		},
		"login_type": {
			"bsonType": "string",
			"description": "登录类型：wx 或 web"
		},
		"nickname": {
			"bsonType": "string",
			"description": "用户昵称"
		},
		"nickname_updated_at": {
			"bsonType": "timestamp",
			"description": "昵称更新时间"
		},
		"password_salt": {
			"bsonType": "string",
			"description": "H5 账号密码盐值"
		},
		"password_hash": {
			"bsonType": "string",
			"description": "H5 账号密码哈希"
		},
		"isAdmin": {
			"bsonType": "bool",
			"description": "是否管理员"
		},
		"create_date": {
			"bsonType": "timestamp",
			"description": "首次登录或注册时间"
		},
		"last_login": {
			"bsonType": "timestamp",
			"description": "最近登录时间"
		},
		"session_token_hash": {
			"bsonType": "string",
			"description": "当前会话 token 哈希"
		},
		"session_expires_at": {
			"bsonType": "timestamp",
			"description": "当前会话过期时间"
		},
		"avatar_fileid": {
			"bsonType": "string",
			"description": "用户头像 uniCloud 文件 fileID"
		},
		"avatar_updated_at": {
			"bsonType": "timestamp",
			"description": "头像更新时间"
		}
	}
}
